<!DOCTYPE html>
<html lang="en">
<head>

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<!-- SEO -->
<meta name="description" content="Abu Shaid Prodhan - Student, Nature & Travel Explorer, Future Software Engineer Portfolio">
<meta name="keywords" content="Abu Shaid, Portfolio, Developer, Photographer, Student">
<meta name="author" content="Abu Shaid Prodhan">

<title>Abu Shaid Prodhan | Developer Portfolio</title>

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;500;700&display=swap" rel="stylesheet">

<style>
*{margin:0;padding:0;box-sizing:border-box;font-family:'Poppins',sans-serif;}

body{
background:#0b0b10;
color:#fff;
line-height:1.8;
scroll-behavior:smooth;
overflow-x:hidden;
}

/* PROGRESS BAR */
#progress{
position:fixed;
top:0;
left:0;
height:4px;
background:#00f2ff;
width:0%;
z-index:2000;
}

/* SECTION */
section{
padding:90px 10%;
max-width:1000px;
margin:auto;
}

h1,h2{
color:#00f2ff;
margin-bottom:15px;
}

.hero{
text-align:center;
padding-top:120px;
}

.hero img{
width:170px;
height:170px;
border-radius:50%;
border:4px solid #00f2ff;
box-shadow:0 0 35px #00f2ff;
margin-bottom:20px;
}

button, .btn{
background:#00f2ff;
color:#000;
padding:10px 20px;
border:none;
border-radius:25px;
cursor:pointer;
margin-top:15px;
font-weight:bold;
}

input, textarea{
width:100%;
padding:12px;
margin:10px 0;
background:#1c1c24;
border:none;
border-radius:8px;
color:#fff;
}

footer{
text-align:center;
padding:40px;
background:#111;
margin-top:40px;
}

a{color:#00f2ff;text-decoration:none;}

</style>
</head>

<body>

<div id="progress"></div>

<section class="hero">
<img src="profile.jpg">
<h1>🌿 Abu Shaid Prodhan</h1>
<p>Student | Nature & Travel Explorer | Future Software Engineer</p>

<!-- Resume Button -->
<a href="resume.pdf" download class="btn">Download Resume</a>

</section>

<section>
<h2>📷 My Photography</h2>
<img src="photo1.jpg" width="100%">
</section>

<section>
<h2>💻 My Skills</h2>
<ul>
<li>Nature Photography</li>
<li>Creative Writing</li>
<li>Learning Programming</li>
<li>Problem Solving</li>
</ul>
</section>

<section>
<h2>📩 Contact Me</h2>

<form>
<input type="text" placeholder="Your Name" required>
<input type="email" placeholder="Your Email" required>
<textarea rows="5" placeholder="Your Message"></textarea>
<button type="submit">Send Message</button>
</form>

</section>

<footer>
🌿 Abu Shaid Prodhan <br>
© 2026 All Rights Reserved
</footer>

<script>
/* PROGRESS */
window.onscroll=function(){
let winScroll=document.documentElement.scrollTop;
let height=document.documentElement.scrollHeight-document.documentElement.clientHeight;
let scrolled=(winScroll/height)*100;
document.getElementById("progress").style.width=scrolled+"%";
};
</script>

</body>
</html>